generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiProvider {
  BAILIAN
  OPENAI
  OTHER
}

enum ExecutionMode {
  DRY_RUN
  LIVE
}

enum UserRole {
  ADMIN
  AGENT
  MEMBER
}

enum CompanyStatus {
  ACTIVE
  TRIAL
  DISABLED
}

enum TemplateStatus {
  ACTIVE
  DRAFT
  DISABLED
}

enum QuoteStatus {
  DRAFT
  GENERATED
  SHARED
  VIEWED
  WON
  LOST
  EXPIRED
}

enum UsageLedgerType {
  TRIAL_GRANT
  ADMIN_GRANT
  AGENT_GRANT
  AI_GENERATION
  ADJUSTMENT
}

enum MarketingTemplateStatus {
  ACTIVE
  DRAFT
  DISABLED
}

enum MarketingGenerationStatus {
  SUCCEEDED
  FAILED
  DRY_RUN
}

enum PlanScope {
  MERCHANT
  AGENT
}

enum MarketingProvisionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  name          String
  role          UserRole      @default(MEMBER)
  isDemo        Boolean       @default(false)
  companyId     String?
  company       Company?      @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: SetNull)
  ownedCompany  Company?      @relation("CompanyOwner")
  agentCompanies Company[]    @relation("CompanyAgent")
  quotes        Quote[]
  aiCallLogs    AiCallLog[]
  usageLedgers  UsageLedger[]
  ownedStores   StoreProfile[]           @relation("StoreOwner")
  ownedAgentProfile AgentProfile?        @relation("AgentOwner")
  marketingGenerations MarketingGenerationRecord[]
  adminOpenedSubscriptions MarketingSubscription[] @relation("SubscriptionOpenedByAdmin")
  marketingOperationLogs MarketingOperationLog[]   @relation("MarketingOperationActor")
  provisionRequests    MarketingProvisionRequest[] @relation("ProvisionRequestedBy")
  reviewedProvisionRequests MarketingProvisionRequest[] @relation("ProvisionReviewedBy")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  status             CompanyStatus      @default(TRIAL)
  ownerId            String?             @unique
  owner              User?              @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  agentId            String?
  agent              User?              @relation("CompanyAgent", fields: [agentId], references: [id], onDelete: SetNull)
  logoUrl            String?
  brandColor         String?
  contactName        String?
  contactPhone       String?
  contactEmail       String?
  usageBalance       Int                @default(0)
  brandProfile       Json?
  users              User[]             @relation("CompanyMembers")
  quotes             Quote[]
  shares             QuoteShare[]
  usageLedgers       UsageLedger[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model IndustryTemplate {
  id                 String           @id @default(cuid())
  code               String           @unique
  name               String
  targetUser         String?
  category           String?
  description        String?
  status             TemplateStatus   @default(ACTIVE)
  isFeatured         Boolean          @default(false)
  sortOrder          Int              @default(0)
  formSchema         Json
  defaultLineItems   Json
  sectionSchema      Json
  promptConfig       Json
  riskDisclosures    Json
  quotes             Quote[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Quote {
  id                    String           @id @default(cuid())
  companyId             String
  company               Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  templateId            String
  template              IndustryTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdById           String
  createdBy             User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  title                 String
  clientName            String
  contactName           String?
  contactPhone          String?
  contactEmail          String?
  status                QuoteStatus      @default(DRAFT)
  currency              String           @default("CNY")
  templateCodeSnapshot  String
  templateNameSnapshot  String
  templateSnapshot      Json
  clientContext         Json?
  formValues            Json
  generatedSections     Json?
  editableSections      Json?
  shareEnabled          Boolean          @default(false)
  subtotalCents         Int              @default(0)
  discountCents         Int              @default(0)
  taxCents              Int              @default(0)
  totalCents            Int              @default(0)
  lastGeneratedAt       DateTime?
  lastViewedAt          DateTime?
  viewCount             Int              @default(0)
  lineItems             QuoteLineItem[]
  shares                QuoteShare[]
  aiCallLogs            AiCallLog[]
  usageLedgers          UsageLedger[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([companyId, createdAt])
  @@index([templateId, status])
}

model QuoteLineItem {
  id             String   @id @default(cuid())
  quoteId        String
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sortOrder      Int      @default(0)
  name           String
  description    String?
  unit           String?
  quantity       Decimal  @db.Decimal(12, 2)
  unitPriceCents Int
  discountCents  Int      @default(0)
  subtotalCents  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([quoteId, sortOrder])
}

model QuoteShare {
  id             String   @id @default(cuid())
  quoteId         String
  quote           Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  token           String   @unique
  isActive        Boolean  @default(true)
  allowPdfDownload Boolean @default(true)
  expiresAt       DateTime?
  firstViewedAt   DateTime?
  lastViewedAt    DateTime?
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([quoteId, isActive])
}

model UsageLedger {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  quoteId        String?
  quote          Quote?           @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  type           UsageLedgerType
  delta          Int
  balanceAfter   Int
  note           String?
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([companyId, createdAt])
}

model AiCallLog {
  id            String        @id @default(cuid())
  provider      AiProvider
  model         String
  executionMode ExecutionMode @default(DRY_RUN)
  promptVersion String?
  latencyMs     Int?
  tokensInput   Int?
  tokensOutput  Int?
  costCents     Int           @default(0)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  requestBody   Json?
  responseBody  Json?
  errorMessage  String?
  createdAt     DateTime      @default(now())

  @@index([quoteId, createdAt])
}

model StoreProfile {
  id                String                     @id @default(cuid())
  ownerUserId       String?
  ownerUser         User?                      @relation("StoreOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name              String
  slug              String                     @unique
  industry          String
  city              String
  district          String?
  businessArea      String?
  avgTicketCents    Int?
  mainProducts      Json?
  sellingPoints     Json?
  targetAudience    String?
  brandTone         String?
  contactPhone      String?
  status            CompanyStatus              @default(TRIAL)
  agentLinks        AgentMerchant[]
  subscriptions     MarketingSubscription[]
  quotas            MarketingQuota[]
  generations       MarketingGenerationRecord[]
  operationLogs     MarketingOperationLog[]
  provisionRequests MarketingProvisionRequest[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model AgentProfile {
  id                String                     @id @default(cuid())
  ownerUserId       String?                    @unique
  ownerUser         User?                      @relation("AgentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  companyName       String
  contactName       String?
  contactPhone      String?
  level             String?
  status            CompanyStatus              @default(TRIAL)
  merchants         AgentMerchant[]
  subscriptions     MarketingSubscription[]
  quotas            MarketingQuota[]
  operationLogs     MarketingOperationLog[]
  provisionRequests MarketingProvisionRequest[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model AgentMerchant {
  id                String                     @id @default(cuid())
  agentId           String
  agent             AgentProfile               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  storeId           String
  store             StoreProfile               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  serviceStatus     String                     @default("ACTIVE")
  notes             String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@unique([agentId, storeId])
}

model MarketingTemplateCategory {
  id                String                     @id @default(cuid())
  name              String
  slug              String                     @unique
  industry          String?
  scene             String?
  platform          String?
  sortOrder         Int                        @default(0)
  isActive          Boolean                    @default(true)
  templates         MarketingTemplate[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model MarketingTemplate {
  id                String                     @id @default(cuid())
  categoryId        String
  category          MarketingTemplateCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name              String
  slug              String                     @unique
  industry          String
  scene             String
  platform          String
  description       String
  inputSchema       Json
  promptTemplate    Json
  exampleOutput     Json?
  isFeatured        Boolean                    @default(false)
  sortOrder         Int                        @default(0)
  status            MarketingTemplateStatus    @default(ACTIVE)
  generations       MarketingGenerationRecord[]
  operationLogs     MarketingOperationLog[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model MarketingGenerationRecord {
  id                String                     @id @default(cuid())
  storeId           String
  store             StoreProfile               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  templateId        String
  template          MarketingTemplate          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdByUserId   String?
  createdByUser     User?                      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  title             String?
  inputPayload      Json
  outputText        String
  outputJson        Json?
  provider          AiProvider                 @default(BAILIAN)
  model             String
  executionMode     ExecutionMode              @default(DRY_RUN)
  status            MarketingGenerationStatus
  errorMessage      String?
  latencyMs         Int?
  tokensInput       Int?
  tokensOutput      Int?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([storeId, createdAt])
  @@index([templateId, createdAt])
}

model MarketingPlan {
  id                String                     @id @default(cuid())
  name              String
  code              String                     @unique
  roleScope         PlanScope
  monthlyQuota      Int
  priceCents        Int
  isActive          Boolean                    @default(true)
  subscriptions     MarketingSubscription[]
  operationLogs     MarketingOperationLog[]
  provisionRequests MarketingProvisionRequest[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model MarketingSubscription {
  id                String                     @id @default(cuid())
  storeId           String?
  store             StoreProfile?              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  agentId           String?
  agent             AgentProfile?              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  planId            String
  plan              MarketingPlan              @relation(fields: [planId], references: [id], onDelete: Restrict)
  status            String                     @default("ACTIVE")
  sourceType        String                     @default("MANUAL")
  startAt           DateTime
  endAt             DateTime
  openedByAdminId   String?
  openedByAdmin     User?                      @relation("SubscriptionOpenedByAdmin", fields: [openedByAdminId], references: [id], onDelete: SetNull)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([storeId, status])
  @@index([agentId, status])
}

model MarketingQuota {
  id                String                     @id @default(cuid())
  storeId           String?
  store             StoreProfile?              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  agentId           String?
  agent             AgentProfile?              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  monthlyLimit      Int
  usedCount         Int                        @default(0)
  resetAt           DateTime
  status            String                     @default("ACTIVE")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([storeId, status])
  @@index([agentId, status])
}

model MarketingProvisionRequest {
  id                String                           @id @default(cuid())
  storeId           String
  store             StoreProfile                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  agentId           String?
  agent             AgentProfile?                    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  planId            String
  plan              MarketingPlan                    @relation(fields: [planId], references: [id], onDelete: Restrict)
  months            Int                              @default(1)
  note              String?
  status            MarketingProvisionRequestStatus  @default(PENDING)
  requestedByUserId String?
  requestedByUser   User?                            @relation("ProvisionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  reviewedByAdminId String?
  reviewedByAdmin   User?                            @relation("ProvisionReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt

  @@index([status, createdAt])
  @@index([storeId, status])
  @@index([agentId, status])
}

model MarketingOperationLog {
  id                String                     @id @default(cuid())
  actorUserId       String?
  actorUser         User?                      @relation("MarketingOperationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action            String
  targetType        String
  targetLabel       String
  detail            String?
  storeId           String?
  store             StoreProfile?              @relation(fields: [storeId], references: [id], onDelete: SetNull)
  agentId           String?
  agent             AgentProfile?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  planId            String?
  plan              MarketingPlan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  templateId        String?
  template          MarketingTemplate?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  metadata          Json?
  createdAt         DateTime                   @default(now())

  @@index([createdAt])
  @@index([targetType, createdAt])
  @@index([storeId, createdAt])
  @@index([agentId, createdAt])
  @@index([planId, createdAt])
  @@index([templateId, createdAt])
}
