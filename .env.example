APP_ENV=development
APP_URL=http://127.0.0.1:3000
COMPOSE_PROJECT_NAME=tiger_local_life_saas

# Local Docker defaults. Keep bind hosts on 127.0.0.1 unless you have a reverse proxy and firewall in place.
WEB_BIND_HOST=127.0.0.1
WEB_PORT=3000
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=tiger_local_life
POSTGRES_PASSWORD=replace_with_random_password
POSTGRES_DB=tiger_local_life
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379

DATABASE_URL=postgresql://tiger_local_life:replace_with_random_password@127.0.0.1:5433/tiger_local_life?schema=public
REDIS_URL=redis://127.0.0.1:6379

S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

OPENAI_API_KEY=
BAILIAN_API_KEY=
AI_DEFAULT_MODEL=qwen3.6-plus
AI_FALLBACK_MODEL=qwen3.7-max
AI_MODEL_PROVIDER=BAILIAN
AI_EXECUTION_MODE=live
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_DAILY_MODEL=qwen3.6-plus
BAILIAN_COMPLEX_MODEL=qwen3.7-max
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=
KIMI_API_KEY=

AUTH_SECRET=replace_with_random_secret
ADMIN_API_KEY=replace_with_random_admin_key

DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_WEBHOOK_SECRET=

WECOM_CORP_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_WEBHOOK_URL=

TENCENT_QIDIAN_APP_ID=
TENCENT_QIDIAN_SECRET=

PAYMENT_SECRET_KEY=
WEBHOOK_SECRET=
